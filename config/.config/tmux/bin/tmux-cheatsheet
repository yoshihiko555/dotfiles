#!/bin/bash
# チートシート選択 → glow で表示
# ~/.config/*/docs/CHEATSHEET.md および
# ~/.config/*/docs/cheatsheet/*.md を検索して fzf で選択

set -euo pipefail

cheatsheets=()

# 単体 CHEATSHEET.md (例: tmux)
for f in ~/.config/*/docs/CHEATSHEET.md; do
  [ -f "$f" ] || continue
  name=$(echo "$f" | sed 's|.*/\.config/\([^/]*\)/.*|\1|')
  cheatsheets+=("$name"$'\t'"$f")
done

# 分割チートシート (例: nvim/docs/cheatsheet/*.md)
for f in ~/.config/*/docs/cheatsheet/*.md; do
  [ -f "$f" ] || continue
  tool=$(echo "$f" | sed 's|.*/\.config/\([^/]*\)/.*|\1|')
  topic=$(basename "$f" .md)
  # README.md は目次なのでスキップ
  [ "$topic" = "README" ] && continue
  cheatsheets+=("$tool/$topic"$'\t'"$f")
done

if [ ${#cheatsheets[@]} -eq 0 ]; then
  echo "No cheatsheets found."
  exit 1
fi

if [ ${#cheatsheets[@]} -eq 1 ]; then
  selected="${cheatsheets[0]}"
else
  selected=$(printf '%s\n' "${cheatsheets[@]}" | \
    fzf --delimiter=$'\t' \
        --with-nth=1 \
        --header="Select cheatsheet" \
        --preview='glow -s dark {2}' \
        --preview-window=right:70%)
fi

[ -z "$selected" ] && exit 0

path=$(echo "$selected" | cut -f2)
glow -s dark -p "$path"
