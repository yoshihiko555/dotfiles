#!/bin/sh
# ステータスバー用セッション一覧（WezTerm タブ風ひし形）
# - claude-* セッションを除外
export PATH="/opt/homebrew/bin:$PATH"

# Powerline Extra グリフ (WezTerm tab.lua 準拠)
# /bin/sh の printf でも壊れないよう UTF-8 バイト列で定義する
LEFT=$(printf '\356\202\272')   # ple_lower_right_triangle
RIGHT=$(printf '\356\202\274')  # ple_upper_left_triangle

current=$(tmux display-message -p '#{session_name}')
sessions=$(tmux ls -F '#{session_name}' 2>/dev/null | grep -v '^claude-' | sort)

i=1
for s in $sessions; do
  if [ "$s" = "$current" ]; then
    printf "#[fg=#3BC1A8,bg=default]${LEFT}#[fg=#1e2030,bg=#3BC1A8,bold] %d  %s #[fg=#3BC1A8,bg=default]${RIGHT}" "$i" "$s"
  else
    printf "#[fg=#005461,bg=default]${LEFT}#[fg=#c8d3f5,bg=#005461] %d  %s #[fg=#005461,bg=default]${RIGHT}" "$i" "$s"
  fi
  i=$((i + 1))
done
