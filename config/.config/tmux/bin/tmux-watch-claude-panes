#!/bin/sh
# ai-orchestra が作った claude 監視セッションの全ペイン出力を capture-pane でリアルタイム表示
# Usage: tmux-watch-claude-panes <session-name>
export PATH="/opt/homebrew/bin:$PATH"

SESSION="$1"
if [ -z "$SESSION" ]; then
  echo "Usage: tmux-watch-claude-panes <session-name>"
  exit 1
fi

TMPDIR="${TMPDIR:-/tmp}"
CURFILE="$TMPDIR/claude-watch-cur-$$"
PREVFILE="$TMPDIR/claude-watch-prev-$$"
RENDER_PID=""

cleanup() {
  if [ -n "$RENDER_PID" ]; then
    kill "$RENDER_PID" 2>/dev/null || true
    wait "$RENDER_PID" 2>/dev/null || true
  fi
  rm -f "$CURFILE" "$PREVFILE"
  printf "\033[?25h"
}

trap 'cleanup; exit 0' INT TERM EXIT

repeat_char() {
  char="$1"
  count="$2"

  if [ -z "$count" ] || [ "$count" -le 0 ]; then
    return
  fi

  awk -v char="$char" -v count="$count" 'BEGIN { for (i = 0; i < count; i++) printf "%s", char }'
}

render_pane_block() {
  pid="$1"
  ptitle="$2"
  cols="$3"
  content_lines="$4"

  inner_width=$((cols - 4))
  if [ "$inner_width" -lt 20 ]; then
    inner_width=20
  fi

  status="RUNNING"
  border_color="\033[36m"
  title="$ptitle"
  case "$ptitle" in
    DONE:*)
      status="DONE"
      border_color="\033[32m"
      title=${ptitle#DONE: }
      ;;
  esac

  printf "%b+%s+\033[0m\n" "$border_color" "$(repeat_char "-" $((cols - 2)))"
  printf "%b| %-*.*s |\033[0m\n" "$border_color" "$inner_width" "$inner_width" "[$status] $title"
  printf "%b| %-*.*s |\033[0m\n" "$border_color" "$inner_width" "$inner_width" "pane=$pid"
  printf "%b+%s+\033[0m\n" "$border_color" "$(repeat_char "-" $((cols - 2)))"

  tmux capture-pane -t "$pid" -p 2>/dev/null \
    | tail -n "$content_lines" \
    | awk -v width="$inner_width" -v lines="$content_lines" '
        {
          line = $0
          if (length(line) > width) line = substr(line, 1, width)
          printf("| %-*s |\n", width, line)
          count++
        }
        END {
          for (i = count; i < lines; i++) {
            printf("| %-*s |\n", width, "")
          }
        }
      '

  printf "%b+%s+\033[0m\n" "$border_color" "$(repeat_char "-" $((cols - 2)))"
}

render_screen() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    printf '\033[H'
    printf "\033[1mCtrl-D で閉じます\033[0m\n"
    printf "\033[1m[%s]\033[0m ended\n" "$SESSION"
    printf '\033[J'
    return 1
  fi

  pane_list=$(tmux list-panes -t "$SESSION" -F '#{pane_id}|#{pane_title}' 2>/dev/null)
  pane_count=$(printf '%s\n' "$pane_list" | awk 'NF { count++ } END { print count + 0 }')
  cols=$(tput cols 2>/dev/null || echo 120)
  rows=$(tput lines 2>/dev/null || echo 40)

  available_rows=$((rows - 5))
  if [ "$available_rows" -lt 12 ]; then
    available_rows=12
  fi

  block_overhead=4
  if [ "$pane_count" -gt 0 ]; then
    content_lines=$((available_rows / pane_count - block_overhead))
  else
    content_lines=8
  fi
  if [ "$content_lines" -lt 4 ]; then
    content_lines=4
  fi

  {
    printf "pane_count=%s  lines_per_pane=%s\n" "$pane_count" "$content_lines"
    printf "========================================\n"

    printf '%s\n' "$pane_list" | while IFS='|' read -r pid ptitle; do
      [ -n "$pid" ] || continue
      render_pane_block "$pid" "$ptitle" "$cols" "$content_lines"
      echo ""
    done
  } > "$CURFILE"

  if ! cmp -s "$CURFILE" "$PREVFILE"; then
    printf '\033[H'
    printf "\033[1mCtrl-D で閉じます\033[0m\n"
    printf "\033[1m[%s]\033[0m \033[2m%s\033[0m\n" "$SESSION" "$(date '+%H:%M:%S')"
    echo "------------------------------------"
    cat "$CURFILE"
    printf '\033[J'
    cp "$CURFILE" "$PREVFILE"
  fi

  return 0
}

render_loop() {
  while true; do
    render_screen || return 0
    sleep 1
  done
}

printf '\033[?25l'  # カーソル非表示
clear
printf "\033[1mCtrl-D で閉じます\033[0m\n"

: > "$PREVFILE"
render_loop &
RENDER_PID=$!

cat >/dev/null
