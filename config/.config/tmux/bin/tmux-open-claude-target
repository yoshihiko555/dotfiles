#!/bin/sh
# TODO(baton): baton 移行後に削除候補。詳細は ~/.config/tmux/docs/BATON-MIGRATION.md
# popup 終了後に親クライアント側で Claude pane へ移動する
export PATH="/opt/homebrew/bin:$PATH"

TARGET_FILE="${TMUX_CLAUDE_TARGET_FILE:-/tmp/tmux-claude-target}"

[ -f "$TARGET_FILE" ] || exit 0

IFS='	' read -r session_name window_index pane_id < "$TARGET_FILE"
rm -f "$TARGET_FILE"

[ -n "$session_name" ] || exit 1

tmux switch-client -t "$session_name" || exit 1

if [ -n "$window_index" ]; then
  tmux select-window -t "${session_name}:${window_index}" 2>/dev/null || true
fi

if [ -n "$pane_id" ]; then
  tmux select-pane -t "$pane_id" 2>/dev/null || true
fi
