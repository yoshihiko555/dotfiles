#!/bin/bash
# tmux-kill-current-session — 現在のセッションを終了する
# 実行中のプロセスがある場合は確認を表示

set -euo pipefail

session=$(tmux display-message -p '#{session_name}')

# シェル以外のプロセスが動いているペインを検出
running=$(tmux list-panes -s -t "$session" -F '#{pane_current_command}' \
  | grep -cvE '^(bash|zsh|fish|sh)$' || true)

if [ "$running" -gt 0 ]; then
  tmux confirm-before -p "#{session_name}: ${running} 個のプロセスが実行中です。セッションを終了しますか? (y/n)" \
    "kill-session -t '$session'"
else
  tmux kill-session -t "$session"
fi
