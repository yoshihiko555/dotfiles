#!/bin/bash
# tmux-split-layout вҖ” зҸҫеңЁгҒ®гӮҰгӮЈгғігғүгӮҰгӮ’ N гғҡгӮӨгғігҒ«еҲҶеүІ
# WezTerm гҒ® layouts.split_to() зӣёеҪ“
# Usage: tmux-split-layout <N>

set -euo pipefail

N="${1:-}"
if [ -z "$N" ] || [ "$N" -lt 2 ] || [ "$N" -gt 8 ]; then
  tmux display-message "дҪҝгҒ„ж–№: tmux-split-layout <2-8>"
  exit 1
fi

# зҸҫеңЁгҒ®гғҡгӮӨгғіж•°гғҒгӮ§гғғгӮҜпјҲ1гғҡгӮӨгғігҒ®гҒҝиЁұеҸҜпјү
pane_count=$(tmux list-panes | wc -l | tr -d ' ')
if [ "$pane_count" -ne 1 ]; then
  tmux display-message "1гғҡгӮӨгғігҒ®гӮҰгӮЈгғігғүгӮҰгҒ§гҒ®гҒҝе®ҹиЎҢгҒ§гҒҚгҒҫгҒҷ (зҸҫеңЁ: ${pane_count}гғҡгӮӨгғі)"
  exit 1
fi

cwd="#{pane_current_path}"

case "$N" in
  # в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”җ
  # в”Ӯ  1   в”Ӯ  2   в”Ӯ
  # в””в”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
  2)
    tmux split-window -h -c "$cwd"
    tmux select-pane -t 0
    ;;

  # в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”җ
  # в”Ӯ      в”Ӯ  2   в”Ӯ
  # в”Ӯ  1   в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
  # в”Ӯ      в”Ӯ  3   в”Ӯ
  # в””в”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
  3)
    tmux split-window -h -c "$cwd" -p 50
    tmux split-window -v -c "$cwd" -p 50
    tmux select-pane -t 0
    ;;

  # в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”җ
  # в”Ӯ  1   в”Ӯ  2   в”Ӯ
  # в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
  # в”Ӯ  3   в”Ӯ  4   в”Ӯ
  # в””в”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
  4)
    tmux split-window -h -c "$cwd" -p 50
    tmux select-pane -t 0
    tmux split-window -v -c "$cwd" -p 50
    tmux select-pane -t 1
    tmux split-window -v -c "$cwd" -p 50
    tmux select-pane -t 0
    ;;

  # в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
  # в”Ӯ   1    в”Ӯ   2    в”Ӯ
  # в”ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”ҙв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Ө
  # в”Ӯ  3  в”Ӯ  4  в”Ӯ  5  в”Ӯ
  # в””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ
  5)
    tmux split-window -v -c "$cwd" -p 50
    tmux select-pane -t 0
    tmux split-window -h -c "$cwd" -p 50
    tmux select-pane -t 2
    tmux split-window -h -c "$cwd" -p 67
    tmux split-window -h -c "$cwd" -p 50
    tmux select-pane -t 0
    ;;

  # в”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ
  # в”Ӯ  1  в”Ӯ  2  в”Ӯ  3  в”Ӯ
  # в”ңв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Ө
  # в”Ӯ  4  в”Ӯ  5  в”Ӯ  6  в”Ӯ
  # в””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ
  6)
    tmux split-window -v -c "$cwd" -p 50
    tmux select-pane -t 0
    tmux split-window -h -c "$cwd" -p 67
    tmux split-window -h -c "$cwd" -p 50
    tmux select-pane -t 3
    tmux split-window -h -c "$cwd" -p 67
    tmux split-window -h -c "$cwd" -p 50
    tmux select-pane -t 0
    ;;

  # в”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”җ
  # в”Ӯ  1  в”Ӯ  2  в”Ӯ  3  в”Ӯ
  # в”ңв”Җв”Җв”Җв”¬в”Җв”ҙв”Җв”Җв”¬в”Җв”Җв”ҙв”Җв”¬в”Җв”Җв”Җв”Ө
  # в”Ӯ 4 в”Ӯ 5  в”Ӯ 6  в”Ӯ 7 в”Ӯ
  # в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ
  7)
    tmux split-window -v -c "$cwd" -p 50
    tmux select-pane -t 0
    tmux split-window -h -c "$cwd" -p 67
    tmux split-window -h -c "$cwd" -p 50
    tmux select-pane -t 3
    tmux split-window -h -c "$cwd" -p 75
    tmux split-window -h -c "$cwd" -p 67
    tmux split-window -h -c "$cwd" -p 50
    tmux select-pane -t 0
    ;;

  # в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ
  # в”Ӯ 1 в”Ӯ 2 в”Ӯ 3 в”Ӯ 4 в”Ӯ
  # в”ңв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Ө
  # в”Ӯ 5 в”Ӯ 6 в”Ӯ 7 в”Ӯ 8 в”Ӯ
  # в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ
  8)
    tmux split-window -v -c "$cwd" -p 50
    tmux select-pane -t 0
    tmux split-window -h -c "$cwd" -p 75
    tmux split-window -h -c "$cwd" -p 67
    tmux split-window -h -c "$cwd" -p 50
    tmux select-pane -t 4
    tmux split-window -h -c "$cwd" -p 75
    tmux split-window -h -c "$cwd" -p 67
    tmux split-window -h -c "$cwd" -p 50
    tmux select-pane -t 0
    ;;
esac
