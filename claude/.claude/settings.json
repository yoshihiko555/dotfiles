{
  "env": {
    "CLAUDE_CODE_SHELL": "bash",
    "AI_ORCHESTRA_DIR": "/Users/yoshihiko/ghq/github.com/yoshihiko555/ai-orchestra",
    "NODE_OPTIONS": "--use-env-proxy"
  },
  "permissions": {
    "allow": [
      "Read",
      "Search",
      "Glob",
      "Grep",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(git *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(codex *)",
      "Bash(gemini *)",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo *)",
      "Bash(*> .env*)",
      "Bash(*>> .env*)",
      "Bash(*credentials*)",
      "Bash(*secret*)",
      "Bash(*password*)",
      "Read(.env)"
    ],
    "additionalDirectories": [
      "//tmp/claude-501",
      "//private/tmp/claude-501"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/claude_message.sh stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/claude_message.sh notification"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/claude_message.sh success"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/claude_message.sh failure"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.py"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "frontend-design@claude-plugins-official": false,
    "Notion@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "language": "日本語",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "generativelanguage.googleapis.com",
        "accounts.google.com",
        "127.0.0.1",
        "mcp.notion.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.gemini"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "docker",
      "docker-compose",
      "codex",
      "gemini",
      "gh"
    ]
  }
}
